# Copy to .env.local for local development (do NOT commit real secrets)

# Public site base URL (optional locally; set after you have a real domain)
# Example: https://example.com
NEXT_PUBLIC_SITE_URL=

# Sanity (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=
# Optional (defaults in code if not set)
NEXT_PUBLIC_SANITY_API_VERSION=

# Sanity preview (optional; required only if you use draft preview)
SANITY_API_READ_TOKEN=
SANITY_PREVIEW_SECRET=

# Sanity revalidation webhook (recommended for production)
SANITY_REVALIDATE_SECRET=

# Telegram integration for form submissions (optional; if missing API will return 500)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
